{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ProductsDb": "Server=(localdb)\\MSSQLLocalDB;Database=ProductsDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ApplyMigrationsOnStartup": true,
  "Jwt": {
    "Issuer": "ZenTek.Products.Api",
    "Audience": "ZenTek.Products.Client",
    "ExpiryMinutes": 60
  },
  "DemoUser": {
    "Username": "demo"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  }
}
